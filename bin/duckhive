#!/usr/bin/env node

/**
 * DuckHive — AI coding CLI harness
 * Auto-starts Council daemon, configures providers, launches Go TUI when available.
 */

import { existsSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'
import { fork, spawn } from 'child_process'

const __dirname = dirname(fileURLToPath(import.meta.url))
const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

function shouldAutoLaunchTui() {
  return (
    process.argv.slice(2).length === 0 &&
    process.stdin.isTTY &&
    process.stdout.isTTY &&
    process.env.DUCKHIVE_NO_AUTO_TUI !== '1'
  )
}

function spawnAndWaitForStart(command, args, env) {
  return new Promise(resolve => {
    const child = spawn(command, args, {
      stdio: 'inherit',
      env,
    })

    const onError = () => resolve(false)
    child.once('error', onError)
    child.once('spawn', () => {
      child.off('error', onError)
      child.on('exit', code => process.exit(code ?? 0))
      resolve(true)
    })
  })
}

async function launchStandaloneTui() {
  const tuiPath = join(__dirname, '..', 'tui', 'duckhive-tui')
  if (!existsSync(tuiPath)) return false

  const env = {
    ...process.env,
    DUCKHIVE_AUTO_TUI: '1',
    DUCKHIVE_BRIDGE_CMD: process.execPath,
    DUCKHIVE_BRIDGE_ARGS: [
      distPath,
      '--print',
      '--verbose',
      '--output-format=stream-json',
      '--input-format=stream-json',
    ].join(' '),
  }

  const helperPath = join(__dirname, 'tui-pty-helper.py')
  if (existsSync(helperPath)) {
    const helperStarted = await spawnAndWaitForStart('python3', [helperPath], env)
    if (helperStarted) return true
  }

  return await spawnAndWaitForStart(tuiPath, [], env)
}

process.env.COUNCIL_PORT ??= '3007'
process.env.HIVE_API_BASE ??= `http://localhost:${process.env.COUNCIL_PORT}`
process.env.DUCKHIVE_COUNCIL_URL ??= process.env.HIVE_API_BASE
process.env.DUCKHIVE_AGENT_TEAMS_ENABLED ??= '1'
process.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS ??= '1'

// ─── Auto-start Council daemon ────────────────────────────────────────────────
async function ensureCouncilDaemon() {
  const COUNCIL_PORT = process.env.COUNCIL_PORT || '3007'
  try {
    const controller = new AbortController()
    const id = setTimeout(() => controller.abort(), 1000)
    const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`, { signal: controller.signal })
    clearTimeout(id)
    if (res.ok) return
  } catch {}
  const councilPath = join(__dirname, '..', 'src', 'services', 'council-server', 'council-api-server.cjs')
  if (!existsSync(councilPath)) return
  const child = fork(councilPath, [], {
    env: { ...process.env, PORT: COUNCIL_PORT, NODE_ENV: 'production' },
    detached: true,
    stdio: 'ignore',
  })
  child.unref()
  const deadline = Date.now() + 5000
  while (Date.now() < deadline) {
    await new Promise(r => setTimeout(r, 200))
    try {
      const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`)
      if (res.ok) return
    } catch {}
  }
}

// ─── Load config ────────────────────────────────────────────────────────────────
let configApply = null
try {
  const loaderPath = join(__dirname, 'duckhive-config-loader.js')
  if (existsSync(loaderPath)) {
    const { loadDuckhiveConfig, applyConfigToEnv } = await import(pathToFileURL(loaderPath).href)
    const config = loadDuckhiveConfig()
    applyConfigToEnv(config)
    configApply = config
  }
} catch (err) {}

// ─── Auto-configure MiniMax ────────────────────────────────────────────────────
if (process.env.MINIMAX_API_KEY && !process.env.CLAUDE_CODE_USE_OPENAI) {
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_API_KEY = process.env.MINIMAX_API_KEY
  process.env.OPENAI_BASE_URL = 'https://api.minimax.io/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'MiniMax-M2.7'
}
const moonshotKey = process.env.KIMI_API_KEY || process.env.MOONSHOT_API_KEY
if (
  moonshotKey &&
  (!process.env.OPENAI_API_KEY ||
    /moonshot/i.test(process.env.OPENAI_BASE_URL || ''))
) {
  process.env.OPENAI_API_KEY = moonshotKey
}
if (!process.env.ANTHROPIC_SMALL_FAST_MODEL) {
  process.env.ANTHROPIC_SMALL_FAST_MODEL = 'gpt-4o-mini'
}
if (
  configApply?.providers?.default === 'kimi' &&
  (process.env.KIMI_API_KEY ||
    process.env.MOONSHOT_API_KEY ||
    /moonshot/i.test(process.env.OPENAI_BASE_URL || ''))
) {
  process.env.CLAUDE_CODE_USE_OPENAI ??= '1'
  process.env.OPENAI_BASE_URL =
    process.env.OPENAI_BASE_URL ||
    process.env.MOONSHOT_BASE_URL ||
    'https://api.moonshot.ai/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'kimi-k2.6'
} else if (configApply?.providers?.default === 'openrouter') {
  process.env.OPENAI_BASE_URL = 'https://openrouter.ai/api/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'minimax/minimax-m2.5:free'
}

// ─── Launch ────────────────────────────────────────────────────────────────────────
if (existsSync(distPath)) {
  await ensureCouncilDaemon()
  if (!(shouldAutoLaunchTui() && (await launchStandaloneTui()))) {
    await import(pathToFileURL(distPath).href)
  }
} else {
  console.error(`duckhive: dist/cli.mjs not found. Run: bun run build`)
  process.exit(1)
}
